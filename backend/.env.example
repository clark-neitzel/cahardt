# Configuração do Banco de Dados (PostgreSQL)
# Exemplo local: postgresql://user:password@localhost:5432/dbname
# Exemplo produção (EasyPanel): postgres://user:password@host:5432/dbname
DATABASE_URL="postgres://usuario:senha@host:5432/banco"

# Porta do Servidor
PORT=3000

# Motor de Orientação Comercial (GPT)
OPENAI_API_KEY="sk-..."

# Versão do build — preencher antes de cada deploy no EasyPanel (ex: git hash ou timestamp)
# Exemplo: APP_VERSION=a1b2c3d  ou  APP_VERSION=20260421-1430
APP_VERSION=
