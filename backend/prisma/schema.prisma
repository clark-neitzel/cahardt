// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Produto {
  id          String  @id @default(uuid())
  contaAzulId String  @unique @map("conta_azul_id")
  codigo      String
  nome        String
  valorVenda  Decimal @map("valor_venda") @db.Decimal(10, 2)
  unidade     String

  // Estoques
  estoqueDisponivel Decimal @default(0) @map("estoque_disponivel") @db.Decimal(12, 3)
  estoqueReservado  Decimal @default(0) @map("estoque_reservado") @db.Decimal(12, 3)
  estoqueTotal      Decimal @default(0) @map("estoque_total") @db.Decimal(12, 3)
  estoqueMinimo     Decimal @default(0) @map("estoque_minimo") @db.Decimal(12, 3)

  // Detalhes
  categoria String?
  descricao String? @db.Text
  ean       String?
  ncm       String?
  status    String? // Status original do CA (ex: 'ativo', 'inativo')
  ativo     Boolean @default(true) // Controle local do App

  // Custos e Pesos
  custoMedio  Decimal? @map("custo_medio") @db.Decimal(12, 2)
  custoManual Decimal? @map("custo_manual") @db.Decimal(12, 2) // custo digitado no app; usado só quando o CA não tem custoMedio
  pesoLiquido Decimal? @map("peso_liquido") @db.Decimal(12, 3)

  // Timestamps
  contaAzulUpdatedAt DateTime? @map("conta_azul_updated_at") // Última atualização no Conta Azul
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  imagens              ProdutoImagem[]
  itens                PedidoItem[]
  promocoes            Promocao[]
  itensDevolvidos      EntregaItemDevolvido[]
  itensDevolucao       DevolucaoItem[]
  metasProdutos        MetaProduto[]
  itensAmostra         AmostraItem[]
  movimentacoesEstoque MovimentacaoEstoque[]
  itensPcp             ItemPcp[]

  // Inteligência Comercial
  categoriaProdutoId      String?           @map("categoria_produto_id")
  categoriaProduto        CategoriaProduto? @relation(fields: [categoriaProdutoId], references: [id])
  produtoSubstitutoId     String?           @map("produto_substituto_id")
  produtoSubstituto       Produto?          @relation("Substituto", fields: [produtoSubstitutoId], references: [id])
  produtoSubstitutoSource Produto[]         @relation("Substituto")
  permiteRecomendacao     Boolean           @default(true) @map("permite_recomendacao")
  prioridadeRecomendacao  Int               @default(1) @map("prioridade_recomendacao")

  etiquetas EtiquetaProduto[]

  kitFestaProduto   KitFestaProduto?
  congeladosProduto CongeladosProduto?

  @@map("produtos")
}

model ProdutoImagem {
  id        String  @id @default(uuid())
  produtoId String  @map("produto_id")
  url       String
  principal Boolean @default(false)
  ordem     Int     @default(0)

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@map("produto_imagens")
}

model SyncLog {
  id                   String   @id @default(uuid())
  tipo                 String // Ex: 'PRODUTOS', 'CLIENTES', 'AUTH'
  status               String // 'SUCESSO', 'ERRO'
  mensagem             String?  @db.Text
  registrosProcessados Int      @default(0) @map("registros_processados")
  dataHora             DateTime @default(now()) @map("data_hora")

  // Detalhes Debug
  requestUrl     String? @map("request_url")
  requestMethod  String? @map("request_method")
  responseStatus Int?    @map("response_status")
  responseBody   String? @map("response_body") @db.Text
  duration       Int?    @default(0)

  @@map("sync_logs")
}

model Cliente {
  // Campos Conta Azul (Obrigatórios com nomes estritos)
  UUID            String    @id @default(uuid())
  Nome            String
  NomeFantasia    String?
  Tipo_Pessoa     String?
  Documento       String?   @unique
  Email           String?
  Telefone        String?
  Ativo           Boolean   @default(true)
  Perfis          String?
  Perfil_Filtro   String?
  Data_Criacao    DateTime?
  Data_Alteracao  DateTime?
  End_Logradouro  String?
  End_Numero      String?
  End_Complemento String?
  End_Bairro      String?
  End_Cidade      String?
  End_Estado      String?
  End_CEP         String?
  End_Pais        String?
  Codigo          String?

  Observacoes_Gerais           String?
  Telefone_Celular             String?
  Telefone_Comercial           String?
  Indicador_Inscricao_Estadual String?
  Outros_Contatos              String?
  Atrasos_Pagamentos           Decimal? @db.Decimal(12, 2)
  Atrasos_Recebimentos         Decimal? @db.Decimal(12, 2)
  Pagamentos_Mes_Atual         Decimal? @db.Decimal(12, 2)
  Recebimentos_Mes_Atual       Decimal? @db.Decimal(12, 2)

  // Campos Internos (App Hardt)
  Dia_de_entrega                 String? // Ex: "SEG,QUA"
  Dia_de_venda                   String? // Ex: "TER,QUI"
  Condicao_de_pagamento          String? // ID da TabelaPreco (sem FK)
  condicoes_pagamento_permitidas String[] @default([]) // Lista de IDs de tabelas de preço/condições
  Flex_utilizado                 Decimal  @default(0) @db.Decimal(14, 2)
  Ponto_GPS                      String? // "lat,lng"
  Situacao_serasa                String? // "APROVADO", "NEGADO", "PENDENTE"
  Serasa_consulta                String? // URL do arquivo principal
  Formas_Atendimento             String[] @default([])

  recebeAvisoPedido Boolean @default(true) @map("recebe_aviso_pedido")

  contaAzulUpdatedAt DateTime? @map("conta_azul_updated_at")
  updated_at         DateTime  @updatedAt

  idVendedor String?   @map("id_vendedor")
  vendedor   Vendedor? @relation(fields: [idVendedor], references: [id])

  arquivos      ClienteArquivo[]
  pedidos       Pedido[]
  leads         Lead[]
  amostras      Amostra[]
  contasReceber ContaReceber[]
  devolucoes    Devolucao[]
  atendimentos  Atendimento[]

  // Indicação (auto-referência: quem indicou este cliente)
  indicacaoId String?   @map("indicacao_id")
  indicacao   Cliente?  @relation("ClienteIndicacao", fields: [indicacaoId], references: [UUID])
  indicados   Cliente[] @relation("ClienteIndicacao")

  // Inteligência Comercial
  categoriaClienteId           String?           @map("categoria_cliente_id")
  categoriaCliente             CategoriaCliente? @relation(fields: [categoriaClienteId], references: [id])
  cicloCompraPersonalizadoDias Int?              @map("ciclo_compra_personalizado_dias")
  insightAtivo                 Boolean           @default(true) @map("insight_ativo")
  observacaoComercialFixa      String?           @map("observacao_comercial_fixa") @db.Text
  clienteInsights              ClienteInsight[]
  iaAnaliseLogs                IaAnaliseLog[]

  // Dados fiscais em tabela separada (a tabela `clientes` atingiu o limite de colunas do Postgres)
  fiscal ClienteFiscal?

  kitFestaCliente   KitFestaCliente?
  congeladosCliente CongeladosCliente?

  @@index([Nome])
  @@index([NomeFantasia])
  @@index([Documento])
  @@index([Codigo])
  @@index([End_Cidade])
  @@index([Perfil_Filtro])
  @@map("clientes")
}

// Dados fiscais do cliente mantidos fora da tabela `clientes` (que já está no teto de 1600 colunas).
// Relação 1-1 com Cliente; a FK fica AQUI, então nenhuma coluna nova é criada em `clientes`.
model ClienteFiscal {
  clienteUuid       String  @id @map("cliente_uuid")
  inscricaoEstadual String? @map("inscricao_estadual")
  cliente           Cliente @relation(fields: [clienteUuid], references: [UUID], onDelete: Cascade)

  @@map("cliente_fiscal")
}

model Pedido {
  id                     String    @id @default(uuid())
  numero                 Int? // Preenchido ao gerar número no CA
  dataVenda              DateTime  @map("data_venda") // Data para entrega (vendedor escolhe)
  observacoes            String?   @db.Text
  idContaFinanceira      String?   @map("id_conta_financeira")
  idCategoria            String?   @map("id_categoria")
  tipoPagamento          String?   @map("tipo_pagamento")
  opcaoCondicaoPagamento String?   @map("opcao_condicao_pagamento")
  nomeCondicaoPagamento  String?   @map("nome_condicao_pagamento") // Nome completo salvo no momento da criação
  qtdParcelas            Int       @default(1) @map("qtd_parcelas")
  primeiroVencimento     DateTime? @map("primeiro_vencimento")
  intervaloDias          Int       @default(0) @map("intervalo_dias")
  especial               Boolean   @default(false) // Pedido especial (sem nota) - não envia ao CA
  bonificacao            Boolean   @default(false) // Pedido bonificação - não envia ao CA, valor total 0, sem contas a receber

  // Status de Integração
  statusEnvio      String    @default("ABERTO") @map("status_envio") // ABERTO, ENVIAR, SINCRONIZANDO, RECEBIDO, ERRO
  idVendaContaAzul String?   @map("id_venda_contaazul") // ID gerado na API 
  situacaoCA       String?   @map("situacao_ca") // APROVADO, FATURADO, EM_ABERTO (Conta Azul Oficial)
  erroEnvio        String?   @map("erro_envio") @db.Text
  enviadoEm        DateTime? @map("enviado_em")

  // UX e Mobile
  flexTotal          Decimal   @default(0) @map("flex_total") @db.Decimal(12, 2)
  valorFrete         Decimal?  @map("valor_frete") @db.Decimal(12, 2)
  latLng             String?   @map("lat_lng") // Ponto GPS capturado na elaboração
  revisaoPendente    Boolean   @default(false) @map("revisao_pendente")
  contaAzulUpdatedAt DateTime? @map("conta_azul_updated_at")
  impressoEm         DateTime? @map("impresso_em")
  whatsappEnviado    Boolean   @default(false) @map("whatsapp_enviado")
  whatsappErro       String?   @map("whatsapp_erro")

  canalOrigem         String?   @map("canal_origem") // Ex: VISITA, WHATSAPP, LIGACAO
  usuarioLancamentoId String?   @map("usuario_lancamento_id")
  usuarioLancamento   Vendedor? @relation("UsuarioLancamento", fields: [usuarioLancamentoId], references: [id])

  // Relacionamentos
  clienteId String  @map("cliente_id")
  cliente   Cliente @relation(fields: [clienteId], references: [UUID])

  vendedorId String?   @map("vendedor_id")
  vendedor   Vendedor? @relation(fields: [vendedorId], references: [id])

  itens PedidoItem[]

  // Embarque e Entregas Logísticas
  embarqueId           String?   @map("embarque_id")
  embarque             Embarque? @relation(fields: [embarqueId], references: [id])
  statusEntrega        String    @default("PENDENTE") @map("status_entrega") // PENDENTE, ENTREGUE, ENTREGUE_PARCIAL, DEVOLVIDO
  dataEntrega          DateTime? @map("data_entrega")
  gpsEntrega           String?   @map("gps_entrega")
  divergenciaPagamento Boolean   @default(false) @map("divergencia_pagamento")
  motivoDevolucao      String?   @map("motivo_devolucao") @db.Text // Motivo geral da devolução (parcial ou total)
  observacaoEntrega    String?   @map("observacao_entrega") @db.Text // Observação geral do motorista na entrega
  prioridadeEntrega    Int?      @map("prioridade_entrega") // Prioridade manual do motorista (1, 2, 3...)

  pagamentosReais      PedidoPagamentoReal[]
  itensDevolvidos      EntregaItemDevolvido[]
  caixaConferencias    CaixaEntregaConferida[]
  contaReceber         ContaReceber?
  movimentacoesEstoque MovimentacaoEstoque[]
  devolucoes           Devolucao[]
  devolucaoFinalizada  Boolean                 @default(false) @map("devolucao_finalizada")
  baixaCaRealizada     Boolean                 @default(false) @map("baixa_ca_realizada") // Baixa no CA já foi feita via caixa
  baixaCaValor         Decimal?                @map("baixa_ca_valor") @db.Decimal(12, 2) // Valor da baixa realizada
  baixaCaEm            DateTime?               @map("baixa_ca_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  kitFestaPedido   KitFestaPedido?
  congeladosPedido CongeladosPedido?

  @@index([statusEnvio])
  @@index([vendedorId])
  @@index([clienteId])
  @@index([dataEntrega])
  @@map("pedidos")
}

model PedidoItem {
  id         String  @id @default(uuid())
  descricao  String? @db.Text // Observação ou nome extra do item
  quantidade Decimal @db.Decimal(12, 3)
  valor      Decimal @db.Decimal(12, 2) // Valor de Venda praticado (com/sem Flex)
  valorBase  Decimal @map("valor_base") @db.Decimal(12, 2) // Valor Tabela + Acréscimo pra calcular Flex
  flexGerado Decimal @default(0) @map("flex_gerado") @db.Decimal(12, 2) // Flex individual do item

  pedidoId String @map("pedido_id")
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  produtoId String  @map("produto_id")
  produto   Produto @relation(fields: [produtoId], references: [id])

  // Promoção aplicada no momento do item
  emPromocao   Boolean @default(false) @map("em_promocao")
  promocaoId   String? @map("promocao_id")
  nomePromocao String? @map("nome_promocao")
  tipoPromocao String? @map("tipo_promocao") // SIMPLES ou CONDICIONAL

  @@map("pedido_itens")
}

model CondicaoPagamento {
  id        String   @id @default(uuid())
  nome      String
  codigo    String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("condicoes_pagamento")
}

model ClienteArquivo {
  id           String   @id @default(uuid())
  cliente_uuid String
  tipo         String // Ex: "SERASA"
  url          String
  criado_em    DateTime @default(now())

  cliente Cliente @relation(fields: [cliente_uuid], references: [UUID], onDelete: Cascade)

  @@map("cliente_arquivos")
}

model ContaAzulConfig {
  id           String   @id @default(uuid())
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresIn    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("conta_azul_config")
}

model Vendedor {
  id              String   @id // CA UUID
  nome            String
  email           String?
  telefone        String?
  idLegado        String?  @map("id_legado")
  flexMensal      Decimal  @default(0) @map("flex_mensal") @db.Decimal(12, 2)
  flexDisponivel  Decimal  @default(0) @map("flex_disponivel") @db.Decimal(12, 2)
  maxDescontoFlex Decimal  @default(100) @map("max_desconto_flex") @db.Decimal(5, 2)
  percentualFlex  Decimal  @default(0) @map("percentual_flex") @db.Decimal(5, 2)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Auth / App
  login      String? @unique
  senha      String?
  permissoes Json?

  // Formas de atendimento que este vendedor pode visualizar na rota
  formasAtendimentoVisiveis String[] @default([]) @map("formas_atendimento_visiveis")

  // Alerta de pedidos não faturados (popup a cada 10 min)
  alertaFaturamento Boolean @default(true) @map("alerta_faturamento")

  clientes                 Cliente[]
  pedidos                  Pedido[]
  pedidosLancados          Pedido[]         @relation("UsuarioLancamento")
  leads                    Lead[]
  atendimentos             Atendimento[]
  atendimentosTransferidos Atendimento[]    @relation("AtendimentoTransferido")
  atendimentosRegistrados  Atendimento[]    @relation("AtendimentoRegistro")
  diarios                  DiarioVendedor[]
  amostrasSolicitadas      Amostra[]        @relation("AmostrasSolicitadas")

  embarques        Embarque[]
  pagamentosFiados PedidoPagamentoReal[] @relation("PagamentosFiados")
  despesas         Despesa[]             @relation("DespesasDoVendedor")
  caixasDiarios    CaixaDiario[]
  metasMensais     MetaMensalVendedor[]
  roteirizacao     Roteirizacao?
  baixasRealizadas Parcela[]             @relation("BaixasRealizadas")

  movimentacoesEstoque MovimentacaoEstoque[]

  devolucoesRegistradas Devolucao[] @relation("DevolucaoRegistrada")
  devolucoesRevertidas  Devolucao[] @relation("DevolucaoRevertida")
  devolucoesMotorista   Devolucao[] @relation("DevolucaoMotorista")

  mensagensAgendadas MensagemAgendada[]

  curriculoAcessos   CurriculoAcesso[]
  curriculoHistorico CurriculoHistorico[]
  comissaoConfigs    ComissaoConfig[]

  @@map("vendedores")
}

model MensagemAgendada {
  id          String    @id @default(uuid())
  vendedorId  String    @map("vendedor_id")
  tipo        String // "meta"
  hora        String // "08:00" (horário SP)
  diasSemana  String[]  @map("dias_semana")
  ativo       Boolean   @default(true)
  ultimoEnvio DateTime? @map("ultimo_envio")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  vendedor Vendedor @relation(fields: [vendedorId], references: [id])

  @@map("mensagens_agendadas")
}

model MovimentacaoEstoque {
  id            String   @id @default(uuid())
  produtoId     String   @map("produto_id")
  vendedorId    String?  @map("vendedor_id")
  pedidoId      String?  @map("pedido_id")
  tipo          String // ENTRADA | SAIDA
  quantidade    Decimal  @db.Decimal(12, 3)
  motivo        String // AJUSTE_MANUAL | PEDIDO_ESPECIAL | PEDIDO_BONIFICACAO | CANCELAMENTO | EXCLUSAO
  observacao    String?
  estoqueAntes  Decimal  @map("estoque_antes") @db.Decimal(12, 3)
  estoqueDepois Decimal  @map("estoque_depois") @db.Decimal(12, 3)
  sincCA        Boolean  @default(false) @map("sinc_ca")
  erroCA        String?  @map("erro_ca")
  createdAt     DateTime @default(now()) @map("created_at")

  produto  Produto   @relation(fields: [produtoId], references: [id])
  vendedor Vendedor? @relation(fields: [vendedorId], references: [id])
  pedido   Pedido?   @relation(fields: [pedidoId], references: [id])

  @@map("movimentacoes_estoque")
}

model AppConfig {
  key   String @id
  value Json

  @@map("app_configs")
}

model TabelaPreco {
  id                          String   @id // id-Pgto (Ex: "1000")
  idCondicao                  String   @map("id_condicao") // ID_CONDICAO (Ex: "AVISTA_DIN")
  nomeCondicao                String   @map("nome_condicao") // NOME_CONDICAO
  tipoPagamento               String?  @map("tipo_pagamento") // TIPO_PAGAMENTO
  opcaoCondicao               String?  @map("opcao_condicao") // opcao_condicao_pagamento
  qtdParcelas                 Int      @default(1) @map("qtd_parcelas")
  parcelasDias                Int      @default(0) @map("parcelas_dias")
  acrescimoPreco              Decimal  @default(0) @map("acrescimo_preco") @db.Decimal(10, 2)
  parcelasPercentuais         Decimal  @default(100) @map("parcelas_percentuais") @db.Decimal(10, 2)
  valorMinimo                 Decimal? @default(0) @map("valor_minimo") @db.Decimal(12, 2)
  exigeBanco                  Boolean  @default(false) @map("exige_banco")
  bancoPadrao                 String?  @map("banco_padrao")
  debitaCaixa                 Boolean  @default(false) @map("debita_caixa")
  ativo                       Boolean  @default(true)
  permiteEspecial             Boolean  @default(false) @map("permite_especial") // Condição disponível para pedidos especiais
  permitePedido               Boolean  @default(true) @map("permite_pedido") // Condição disponível para pedidos comuns
  permiteBonificacao          Boolean  @default(false) @map("permite_bonificacao") // Condição disponível para pedidos bonificação
  obs                         String?
  formasRecebimentoPermitidas Json?    @map("formas_recebimento_permitidas") // IDs das formas de recebimento permitidas na entrega: ["tabela_1000", "uuid-forma"]
  permiteDevolucaoTotal       Boolean  @default(true) @map("permite_devolucao_total")
  permiteDevolucaoParcial     Boolean  @default(true) @map("permite_devolucao_parcial")
  regrasCategoria             Json?    @map("regras_categoria") // Regras de preço por categoria CA para especiais: [{ categoria, precoBase, acrescimo }]
  categoriasEspecial          Json?    @map("categorias_especial") // Categorias de produto visíveis em pedidos especiais: ["cat1", "cat2"]
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("tabela_precos")
}

model ContaFinanceira {
  id              String    @id // ID_CONTA_FINANCEIRA
  nomeBanco       String    @map("nome_banco") // NOME_BANCO
  tipoUso         String    @map("tipo_uso") // TIPO_USO
  ativo           Boolean   @default(true)
  ultimaCapturaEm DateTime? @map("ultima_captura_em") // ULTIMA_CAPTURA_EM
  fonteVendaId    String?   @map("fonte_venda_id") // FONTE_VENDA_ID
  obs             String?
  opcaoCondicao   String?   @map("opcao_condicao") // OPCAO_CONDICAO (Visual reference)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("contas_financeiras")
}

// =============================================
// SISTEMA DE PROMOÇÕES
// =============================================

model Promocao {
  id               String   @id @default(uuid())
  produtoId        String   @map("produto_id")
  nome             String
  tipo             String // SIMPLES ou CONDICIONAL
  precoPromocional Decimal  @map("preco_promocional") @db.Decimal(10, 2)
  dataInicio       DateTime @map("data_inicio")
  dataFim          DateTime @map("data_fim")
  status           String   @default("ATIVA") // ATIVA ou ENCERRADA

  // Auditoria de criação
  criadoPor String   @map("criado_por") // vendedorId
  criadoEm  DateTime @default(now()) @map("criado_em")

  // Auditoria de encerramento
  encerradoPor           String?   @map("encerrado_por") // vendedorId
  encerradoEm            DateTime? @map("encerrado_em")
  encerradaAntesPrevisto Boolean?  @map("encerrada_antes_previsto")

  produto        Produto                 @relation(fields: [produtoId], references: [id])
  grupos         PromocaoCondicaoGrupo[]
  metasPromocoes MetaPromocao[]

  @@index([produtoId])
  @@index([status])
  @@map("promocoes")
}

model PromocaoCondicaoGrupo {
  id         String @id @default(uuid())
  promocaoId String @map("promocao_id")

  promocao  Promocao           @relation(fields: [promocaoId], references: [id], onDelete: Cascade)
  condicoes PromocaoCondicao[]

  @@index([promocaoId])
  @@map("promocao_condicao_grupos")
}

model PromocaoCondicao {
  id               String   @id @default(uuid())
  grupoId          String   @map("grupo_id")
  tipo             String // PRODUTO_QUANTIDADE ou VALOR_TOTAL
  produtoId        String?  @map("produto_id") // Para tipo PRODUTO_QUANTIDADE
  quantidadeMinima Decimal? @map("quantidade_minima") @db.Decimal(12, 3)
  valorMinimo      Decimal? @map("valor_minimo") @db.Decimal(12, 2)

  grupo PromocaoCondicaoGrupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@index([grupoId])
  @@map("promocao_condicoes")
}

// =============================================
// MODULO CRM: ROTA + LEADS
// =============================================

model Lead {
  id                  String    @id @default(uuid())
  numero              Int       @default(autoincrement())
  nomeEstabelecimento String    @map("nome_estabelecimento")
  contato             String?
  whatsapp            String?
  diasVisita          String?   @map("dias_visita")
  horarioAtendimento  String?   @map("horario_atendimento")
  horarioEntrega      String?   @map("horario_entrega")
  formasAtendimento   String[]  @default([]) @map("formas_atendimento")
  pontoGps            String?   @map("ponto_gps")
  etapa               String    @default("NOVO")
  proximaVisita       DateTime? @map("proxima_visita")
  observacoes         String?   @db.Text
  fotoFachada         String?   @map("foto_fachada")

  cidade             String?
  origemLead         String?           @map("origem_lead")
  categoriaClienteId String?           @map("categoria_cliente_id")
  categoriaCliente   CategoriaCliente? @relation(fields: [categoriaClienteId], references: [id])

  idVendedor String?   @map("id_vendedor")
  vendedor   Vendedor? @relation(fields: [idVendedor], references: [id])

  clienteId String?  @map("cliente_id")
  cliente   Cliente? @relation(fields: [clienteId], references: [UUID])

  atendimentos Atendimento[]
  amostras     Amostra[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([idVendedor])
  @@index([etapa])
  @@index([clienteId])
  @@map("leads")
}

model Atendimento {
  id            String    @id @default(uuid())
  tipo          String
  observacao    String?   @db.Text
  etapaAnterior String?   @map("etapa_anterior")
  etapaNova     String?   @map("etapa_nova")
  proximaVisita DateTime? @map("proxima_visita")
  gpsVendedor   String?   @map("gps_vendedor")
  pedidoId      String?   @map("pedido_id")

  // Ação estruturada
  acaoKey   String? @map("acao_key")
  acaoLabel String? @map("acao_label")

  // Transferência
  transferidoParaId         String?   @map("transferido_para_id")
  transferidoPara           Vendedor? @relation("AtendimentoTransferido", fields: [transferidoParaId], references: [id])
  transferenciaFinalizada   Boolean   @default(false) @map("transferencia_finalizada")
  transferenciaFinalizadaEm DateTime? @map("transferencia_finalizada_em")
  transferenciaVistaOrigem  Boolean   @default(false) @map("transferencia_vista_origem")

  // Retorno
  assuntoRetorno String?   @map("assunto_retorno") @db.Text
  dataRetorno    DateTime? @map("data_retorno")

  // Alerta visual
  alertaVisualAtivo Boolean @default(false) @map("alerta_visual_ativo")
  alertaVisualCor   String? @map("alerta_visual_cor")
  alertaVisualVisto Boolean @default(false) @map("alerta_visual_visto")

  // Amostra vinculada
  amostraId String?  @map("amostra_id")
  amostra   Amostra? @relation(fields: [amostraId], references: [id])

  leadId    String?  @map("lead_id")
  lead      Lead?    @relation(fields: [leadId], references: [id])
  clienteId String?  @map("cliente_id")
  cliente   Cliente? @relation(fields: [clienteId], references: [UUID])

  idVendedor String   @map("id_vendedor")
  vendedor   Vendedor @relation(fields: [idVendedor], references: [id])

  // Usuário real que registrou o atendimento (pode ser diferente do vendedor responsável pelo cliente)
  usuarioRegistroId String?   @map("usuario_registro_id")
  usuarioRegistro   Vendedor? @relation("AtendimentoRegistro", fields: [usuarioRegistroId], references: [id])

  criadoEm DateTime @default(now()) @map("criado_em")

  @@index([leadId])
  @@index([clienteId])
  @@index([idVendedor])
  @@index([transferidoParaId])
  @@index([dataRetorno])
  @@index([alertaVisualAtivo])
  @@map("atendimentos")
}

// =============================================
// MÓDULO PONTO E VEÍCULOS (DIÁRIO / GATE)
// =============================================

model Veiculo {
  id           String   @id @default(uuid())
  placa        String   @unique
  modelo       String
  documentoUrl String?  @map("documento_url")
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Seguro
  seguroVencimento DateTime? @map("seguro_vencimento")
  seguroApolice    String?   @map("seguro_apolice")
  seguroSeguradora String?   @map("seguro_seguradora")
  seguroApoliceUrl String?   @map("seguro_apolice_url")

  // Métricas e Configurações
  capacidadeTanque Decimal? @map("capacidade_tanque") @db.Decimal(8, 2)
  kmMedioSugerido  Int?     @map("km_medio_sugerido")
  tipoCombustivel  String?  @map("tipo_combustivel") // "DIESEL" | "GASOLINA"
  observacoes      String?  @db.Text

  diarios           DiarioVendedor[]
  despesas          Despesa[]
  alertasManutencao ManutencaoAlerta[]

  @@map("veiculos")
}

model DiarioVendedor {
  id             String @id @default(uuid())
  vendedorId     String @map("vendedor_id")
  modo           String // HOME_OFFICE ou PRESENCIAL
  dataReferencia String @map("data_referencia") // YYYY-MM-DD para busca exata (sem HH:MM)

  // Se Presencial
  veiculoId String? @map("veiculo_id")
  kmInicial Int?    @map("km_inicial")
  kmFinal   Int?    @map("km_final")
  checklist Json? // Array de booleans/strings
  obs       String? @db.Text

  // Timestamps de Ponto
  inicioHora DateTime  @default(now()) @map("inicio_hora")
  fimHora    DateTime? @map("fim_hora")

  vendedor Vendedor @relation(fields: [vendedorId], references: [id])
  veiculo  Veiculo? @relation(fields: [veiculoId], references: [id])

  @@unique([vendedorId, dataReferencia])
  @@index([vendedorId])
  @@index([dataReferencia])
  @@index([veiculoId])
  @@map("diario_vendedor")
}

// =============================================
// MÓDULO EMBARQUE E ENTREGAS 
// =============================================

model Embarque {
  id        String   @id @default(uuid())
  numero    Int      @default(autoincrement())
  dataSaida DateTime @map("data_saida")

  responsavelId String   @map("responsavel_id") // Vendedor/Usuário responsável
  responsavel   Vendedor @relation(fields: [responsavelId], references: [id])

  pedidos  Pedido[]
  amostras Amostra[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("embarques")
}

model ClienteInsight {
  clienteId                   String    @id @map("cliente_id")
  dataUltimoPedido            DateTime? @map("data_ultimo_pedido")
  diasSemComprar              Int?      @map("dias_sem_comprar")
  cicloReferenciaDias         Int       @map("ciclo_referencia_dias")
  origemCiclo                 String    @map("origem_ciclo") // PERSONALIZADO, CATEGORIA, PADRAO
  statusRecompra              String    @map("status_recompra") // SEM_HISTORICO, NO_PRAZO, ATENCAO, ATRASADO, CRITICO
  qtdPedidosUltimos30d        Int       @default(0) @map("qtd_pedidos_ultimos_30d")
  ticketMedioBase             Decimal?  @map("ticket_medio_base") @db.Decimal(12, 2)
  ticketMedioRecente          Decimal?  @map("ticket_medio_recente") @db.Decimal(12, 2)
  variacaoTicketPct           Decimal?  @map("variacao_ticket_pct") @db.Decimal(8, 2)
  itensMediosBase             Decimal?  @map("itens_medios_base") @db.Decimal(10, 2)
  itensMediosRecentes         Decimal?  @map("itens_medios_recentes") @db.Decimal(10, 2)
  variacaoItensPct            Decimal?  @map("variacao_itens_pct") @db.Decimal(8, 2)
  produtoAusenteId            String?   @map("produto_ausente_id")
  produtoAusenteFrequencia    Int       @default(0) @map("produto_ausente_frequencia")
  produtoAusenteDesdePedidos  Int       @default(0) @map("produto_ausente_desde_pedidos")
  categoriaEmQuedaId          String?   @map("categoria_em_queda_id")
  categoriaQuedaPct           Decimal?  @map("categoria_queda_pct") @db.Decimal(8, 2)
  teveDevolucaoRecente        Boolean   @default(false) @map("teve_devolucao_recente")
  dataUltimaDevolucao         DateTime? @map("data_ultima_devolucao")
  motivoUltimaDevolucao       String?   @map("motivo_ultima_devolucao") @db.Text
  qtdAtendimentosSemPedido30d Int       @default(0) @map("qtd_atendimentos_sem_pedido_30d")
  dataUltimoAtendimento       DateTime? @map("data_ultimo_atendimento")
  canalUltimoAtendimento      String?   @map("canal_ultimo_atendimento")
  scoreRisco                  Int       @default(0) @map("score_risco")
  scoreOportunidade           Int       @default(0) @map("score_oportunidade")
  insightPrincipalTipo        String?   @map("insight_principal_tipo")
  insightPrincipalResumo      String?   @map("insight_principal_resumo") @db.Text
  proximaAcaoSugerida         String?   @map("proxima_acao_sugerida") @db.Text
  orientacaoIaJson            Json?     @map("orientacao_ia_json") // Análise gerada por IA (GPT-4o-mini)
  recalculadoEm               DateTime  @map("recalculado_em")

  cliente Cliente @relation(fields: [clienteId], references: [UUID], onDelete: Cascade)

  @@index([recalculadoEm(sort: Desc)])
  @@index([statusRecompra])
  @@index([scoreRisco])
  @@map("cliente_insights")
}

model FormaPagamentoEntrega {
  id                           String   @id @default(uuid())
  nome                         String
  permiteVendedorResponsavel   Boolean  @default(false) @map("permite_vendedor_responsavel")
  permiteEscritorioResponsavel Boolean  @default(false) @map("permite_escritorio_responsavel")
  ativo                        Boolean  @default(true)
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  pagamentosReais PedidoPagamentoReal[]

  @@map("formas_pagamento_entrega")
}

model PedidoPagamentoReal {
  id                      String  @id @default(uuid())
  pedidoId                String  @map("pedido_id")
  formaPagamentoEntregaId String? @map("forma_pagamento_entrega_id")

  formaPagamentoNome String  @map("forma_pagamento_nome") // Nome na hora, para histórico
  valor              Decimal @db.Decimal(12, 2)

  // Responsabilidade em caso de Dívida/Ação
  vendedorResponsavelId String? @map("vendedor_responsavel_id")
  escritorioResponsavel Boolean @default(false) @map("escritorio_responsavel")

  pedido              Pedido                 @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  formaPagamento      FormaPagamentoEntrega? @relation(fields: [formaPagamentoEntregaId], references: [id])
  vendedorResponsavel Vendedor?              @relation("PagamentosFiados", fields: [vendedorResponsavelId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("pedido_pagamentos_reais")
}

model EntregaItemDevolvido {
  id            String  @id @default(uuid())
  pedidoId      String  @map("pedido_id")
  produtoId     String  @map("produto_id")
  quantidade    Decimal @db.Decimal(12, 3)
  valorBaseItem Decimal @map("valor_base_item") @db.Decimal(12, 2) // Valor do item devolvido para registro e cálculo de estorno

  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("entrega_itens_devolvidos")
}

// =============================================
// MÓDULO CAIXA DIÁRIO E DESPESAS
// =============================================

model Despesa {
  id             String @id @default(uuid())
  vendedorId     String @map("vendedor_id")
  dataReferencia String @map("data_referencia") // YYYY-MM-DD

  categoria String // MERCADORIA_EMPRESA | COMBUSTIVEL | PEDAGIO_BALSA | HOTEL_HOSPEDAGEM | MANUTENCAO_VEICULO | OUTRO
  descricao String? @db.Text
  valor     Decimal @db.Decimal(12, 2)

  // Combustivel-specific
  veiculoId         String?  @map("veiculo_id")
  litros            Decimal? @db.Decimal(10, 3)
  kmNoAbastecimento Int?     @map("km_no_abastecimento")

  // Manutencao-specific
  tipoManutencao String? @map("tipo_manutencao") // LAMPADA | PNEU | OLEO | FILTRO | OUTRO

  criadoPor String   @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendedor Vendedor @relation("DespesasDoVendedor", fields: [vendedorId], references: [id])
  veiculo  Veiculo? @relation(fields: [veiculoId], references: [id])

  @@index([vendedorId])
  @@index([dataReferencia])
  @@index([categoria])
  @@map("despesas")
}

model CaixaDiario {
  id             String @id @default(uuid())
  vendedorId     String @map("vendedor_id")
  dataReferencia String @map("data_referencia") // YYYY-MM-DD

  adiantamento Decimal @default(0) @db.Decimal(12, 2)
  status       String  @default("ABERTO") // ABERTO | FECHADO | CONFERIDO

  // Snapshots ao fechar
  totalDespesas       Decimal? @map("total_despesas") @db.Decimal(12, 2)
  totalRecebidoCaixa  Decimal? @map("total_recebido_caixa") @db.Decimal(12, 2)
  totalRecebidoOutros Decimal? @map("total_recebido_outros") @db.Decimal(12, 2)
  valorAPrestar       Decimal? @map("valor_a_prestar") @db.Decimal(12, 2)

  conferidoPor String?   @map("conferido_por")
  conferidoEm  DateTime? @map("conferido_em")
  obsAdmin     String?   @map("obs_admin") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendedor           Vendedor                @relation(fields: [vendedorId], references: [id])
  entregasConferidas CaixaEntregaConferida[]

  @@unique([vendedorId, dataReferencia])
  @@index([vendedorId])
  @@index([dataReferencia])
  @@index([status])
  @@map("caixa_diario")
}

model CaixaEntregaConferida {
  id            String @id @default(uuid())
  caixaDiarioId String @map("caixa_diario_id")
  pedidoId      String @map("pedido_id")

  conferido    Boolean   @default(false)
  conferidoPor String?   @map("conferido_por")
  conferidoEm  DateTime? @map("conferido_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  caixaDiario CaixaDiario @relation(fields: [caixaDiarioId], references: [id], onDelete: Cascade)
  pedido      Pedido      @relation(fields: [pedidoId], references: [id])

  @@unique([caixaDiarioId, pedidoId])
  @@map("caixa_entrega_conferida")
}

// =============================================
// LOG DE AUDITORIA (AÇÕES ADMINISTRATIVAS)
// =============================================

model AuditLog {
  id          String   @id @default(uuid())
  acao        String // REVERTER_CONFERENCIA | REABRIR_CAIXA
  entidade    String // "CaixaDiario"
  entidadeId  String   @map("entidade_id")
  detalhes    String?  @db.Text
  usuarioId   String   @map("usuario_id")
  usuarioNome String   @map("usuario_nome")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entidade, entidadeId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================
// MÓDULO MANUTENÇÃO DE VEÍCULOS
// =============================================

model ManutencaoAlerta {
  id        String @id @default(uuid())
  veiculoId String @map("veiculo_id")

  tipo      String // REVISAO | RODIZIO_PNEUS | TROCA_OLEO | TROCA_FILTRO | OUTRO
  descricao String? @db.Text

  kmAlerta   Int?      @map("km_alerta")
  dataAlerta DateTime? @map("data_alerta")

  concluido    Boolean   @default(false)
  concluidoEm  DateTime? @map("concluido_em")
  concluidoPor String?   @map("concluido_por")

  criadoPor String   @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  veiculo Veiculo @relation(fields: [veiculoId], references: [id])

  @@index([veiculoId])
  @@index([concluido])
  @@map("manutencao_alertas")
}

// =============================================
// MÓDULO ROTEIRIZAÇÃO (SALVA POR USUÁRIO)
// =============================================

model Roteirizacao {
  id         String @id @default(uuid())
  vendedorId String @unique @map("vendedor_id")

  dadosConfig Json // configs used { horaSaida, tempoParadaMin, etc }
  sequencia   Json // the actual route array
  semGPS      Json // orders without GPS
  resumo      Json // distance/duration summary

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendedor Vendedor @relation(fields: [vendedorId], references: [id], onDelete: Cascade)

  @@map("roteirizacoes")
}

// =============================================
// MÓDULO METAS E PROJEÇÕES DE VENDAS
// =============================================

model MetaMensalVendedor {
  id            String @id @default(uuid())
  vendedorId    String @map("vendedor_id")
  mesReferencia String @map("mes_referencia") // Formato "YYYY-MM" (ex: "2026-03")

  diasTrabalho Json    @map("dias_trabalho") // Array de strings "YYYY-MM-DD" representando dias úteis atuantes
  valorMensal  Decimal @map("valor_mensal") @db.Decimal(12, 2)
  flexMensal   Decimal @default(0) @map("flex_mensal") @db.Decimal(12, 2)

  criadoPor String   @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendedor       Vendedor       @relation(fields: [vendedorId], references: [id])
  metasProdutos  MetaProduto[]
  metasPromocoes MetaPromocao[]
  metasCidades   MetaCidade[]

  @@unique([vendedorId, mesReferencia])
  @@index([vendedorId])
  @@index([mesReferencia])
  @@map("meta_mensal_vendedor")
}

model MetaProduto {
  id                   String  @id @default(uuid())
  metaMensalVendedorId String  @map("meta_mensal_vendedor_id")
  produtoId            String  @map("produto_id")
  quantidade           Decimal @db.Decimal(12, 3)

  metaMensalVendedor MetaMensalVendedor @relation(fields: [metaMensalVendedorId], references: [id], onDelete: Cascade)
  produto            Produto            @relation(fields: [produtoId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([metaMensalVendedorId, produtoId])
  @@map("meta_produtos")
}

model MetaPromocao {
  id                   String @id @default(uuid())
  metaMensalVendedorId String @map("meta_mensal_vendedor_id")
  promocaoId           String @map("promocao_id")
  quantidadePedidos    Int    @map("quantidade_pedidos") // Quantos pedidos com a promoção devem ser feitos

  metaMensalVendedor MetaMensalVendedor @relation(fields: [metaMensalVendedorId], references: [id], onDelete: Cascade)
  promocao           Promocao           @relation(fields: [promocaoId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([metaMensalVendedorId, promocaoId])
  @@map("meta_promocoes")
}

model MetaCidade {
  id                   String  @id @default(uuid())
  metaMensalVendedorId String  @map("meta_mensal_vendedor_id")
  cidade               String
  valor                Decimal @db.Decimal(12, 2)
  diasSemana           String? @map("dias_semana") // Ex: "SEG,QUI" — dias de entrega configurados pelo admin

  metaMensalVendedor MetaMensalVendedor @relation(fields: [metaMensalVendedorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([metaMensalVendedorId, cidade])
  @@index([metaMensalVendedorId])
  @@map("meta_cidades")
}

// =============================================
// MÓDULO AMOSTRAS (MINI-PEDIDO SEM PREÇO)
// =============================================

model Amostra {
  id              String        @id @default(uuid())
  numero          Int           @default(autoincrement())
  leadId          String?       @map("lead_id")
  lead            Lead?         @relation(fields: [leadId], references: [id])
  clienteId       String?       @map("cliente_id")
  cliente         Cliente?      @relation(fields: [clienteId], references: [UUID])
  dataEntrega     DateTime?     @map("data_entrega")
  observacao      String?       @db.Text
  status          String        @default("SOLICITADA") // SOLICITADA | PREPARACAO | LIBERADO | ENTREGUE | CANCELADA
  solicitadoPorId String        @map("solicitado_por_id")
  solicitadoPor   Vendedor      @relation("AmostrasSolicitadas", fields: [solicitadoPorId], references: [id])
  embarqueId      String?       @map("embarque_id")
  embarque        Embarque?     @relation(fields: [embarqueId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  itens           AmostraItem[]
  atendimentos    Atendimento[]

  @@index([status])
  @@index([leadId])
  @@index([embarqueId])
  @@map("amostras")
}

model AmostraItem {
  id          String  @id @default(uuid())
  amostraId   String  @map("amostra_id")
  amostra     Amostra @relation(fields: [amostraId], references: [id], onDelete: Cascade)
  produtoId   String  @map("produto_id")
  produto     Produto @relation(fields: [produtoId], references: [id])
  quantidade  Decimal @db.Decimal(12, 3)
  nomeProduto String  @map("nome_produto") // "Amostra - {nome original}"

  @@map("amostra_itens")
}

// =============================================
// MÓDULO INTELIGÊNCIA COMERCIAL (BASE CADASTRAL)
// =============================================

model CategoriaProduto {
  id              String   @id @default(uuid())
  nome            String   @unique
  descricao       String?  @db.Text
  ordemExibicao   Int      @default(0) @map("ordem_exibicao")
  corTag          String?  @map("cor_tag")
  permiteFracao   Boolean  @default(false) @map("permite_fracao")
  controlaEstoque Boolean  @default(false) @map("controla_estoque")
  ativo           Boolean  @default(true)
  tipoFlex        String   @default("NORMAL") @map("tipo_flex") // legado — mantido para não dropar a coluna
  flexPositivo    Boolean  @default(true) @map("flex_positivo") // acréscimos somam no saldo?
  flexNegativo    Boolean  @default(true) @map("flex_negativo") // descontos descontam do saldo?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  produtos Produto[]

  @@map("categorias_produto")
}

// Categorias de produto vindas do Conta Azul (ex: Produto Acabado, Materia Prima)
// Controla quais categorias participam do controle de estoque local
model CategoriaEstoque {
  id              String   @id @default(uuid())
  nome            String   @unique
  controlaEstoque Boolean  @default(false) @map("controla_estoque")
  // Se false, produtos desta categoria CA são excluídos do cálculo de flex
  contabilizaFlex Boolean  @default(true) @map("contabiliza_flex")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("categorias_estoque")
}

// ── Delivery (Kit Festa) ──
// Módulo isolado: pedidos que tenham item em categoria marcada aparecem no Kanban.

model DeliveryCategoria {
  id                      String   @id @default(uuid())
  nome                    String   @unique
  ativo                   Boolean  @default(true)
  // IDs de CategoriaProduto (sub-filtro). Vazio/null = aceita todos os produtos da categoria CA.
  categoriasComerciaisIds Json?    @map("categorias_comerciais_ids")
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("delivery_categorias")
}

model DeliveryStatus {
  id                String   @id @default(uuid())
  pedidoId          String   @unique @map("pedido_id")
  etapa             String   @default("PEDIDO") // PEDIDO | PRODUCAO | SAINDO | ENTREGUE
  etapaAt           DateTime @default(now()) @map("etapa_at")
  // Quando true, movimentações não disparam WhatsApp para o cliente (bot interno continua).
  silenciarWhatsapp Boolean  @default(false) @map("silenciar_whatsapp")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([etapa])
  @@map("delivery_status")
}

model DeliveryPermissao {
  id               String   @id @default(uuid())
  vendedorId       String   @unique @map("vendedor_id")
  podeVer          Boolean  @default(false) @map("pode_ver")
  etapasPermitidas String[] @default([]) @map("etapas_permitidas")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("delivery_permissoes")
}

model DeliveryWebhookLog {
  id        String   @id @default(uuid())
  pedidoId  String   @map("pedido_id")
  etapa     String
  destino   String // BOT | WHATSAPP
  status    String // OK | ERRO
  mensagem  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([pedidoId])
  @@map("delivery_webhook_logs")
}

model CategoriaCliente {
  id                String   @id @default(uuid())
  nome              String   @unique
  descricao         String?  @db.Text
  cicloPadraoDias   Int      @default(7) @map("ciclo_padrao_dias")
  isentoFlex        Boolean  @default(false) @map("isento_flex")
  semLimiteDesconto Boolean  @default(false) @map("sem_limite_desconto")
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  clientes Cliente[]
  leads    Lead[]

  @@map("categorias_cliente")
}

// ── Contas a Receber ──

model ContaReceber {
  id         String  @id @default(uuid())
  pedidoId   String? @unique @map("pedido_id")
  pedido     Pedido? @relation(fields: [pedidoId], references: [id])
  clienteId  String  @map("cliente_id")
  cliente    Cliente @relation(fields: [clienteId], references: [UUID])
  origem     String  @default("ESPECIAL") // ESPECIAL | FATURADO_CA
  valorTotal Decimal @map("valor_total") @db.Decimal(12, 2)
  status     String  @default("ABERTO") // ABERTO | PARCIAL | QUITADO | CANCELADO
  observacao String? @db.Text

  parcelas Parcela[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clienteId])
  @@index([status])
  @@map("contas_receber")
}

model Parcela {
  id             String       @id @default(uuid())
  contaReceberId String       @map("conta_receber_id")
  contaReceber   ContaReceber @relation(fields: [contaReceberId], references: [id], onDelete: Cascade)
  numeroParcela  Int          @map("numero_parcela")
  valor          Decimal      @db.Decimal(12, 2)
  dataVencimento DateTime     @map("data_vencimento")

  // Baixa
  dataPagamento  DateTime? @map("data_pagamento")
  valorPago      Decimal?  @map("valor_pago") @db.Decimal(12, 2)
  formaPagamento String?   @map("forma_pagamento")
  baixadoPorId   String?   @map("baixado_por_id")
  baixadoPor     Vendedor? @relation("BaixasRealizadas", fields: [baixadoPorId], references: [id])
  status         String    @default("PENDENTE") // PENDENTE | PAGO | VENCIDO | CANCELADO
  observacao     String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([contaReceberId])
  @@index([dataVencimento])
  @@index([status])
  @@map("parcelas")
}

// =============================================
// PCP - Planejamento e Controle de Produção
// =============================================

model ItemPcp {
  id        String  @id @default(uuid())
  codigo    String  @unique
  nome      String
  tipo      String // MP | SUB | PA | EMB
  unidade   String // KG | UN | L | PCT | CX
  descricao String? @db.Text
  ativo     Boolean @default(true)

  estoqueAtual     Decimal @default(0) @map("estoque_atual") @db.Decimal(12, 3)
  estoqueMinimo    Decimal @default(0) @map("estoque_minimo") @db.Decimal(12, 3)
  estoqueReservado Decimal @default(0) @map("estoque_reservado") @db.Decimal(12, 3)

  produtoId     String?  @map("produto_id")
  produto       Produto? @relation(fields: [produtoId], references: [id])
  custoUnitario Decimal? @map("custo_unitario") @db.Decimal(12, 4)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  receitasComoResultado Receita[]
  receitaItens          ReceitaItem[]
  ordensConsumo         OrdemConsumo[]
  movimentacoesPcp      MovimentacaoPcp[]
  sugestoes             SugestaoProducao[]

  @@index([tipo])
  @@index([produtoId])
  @@map("itens_pcp")
}

model Receita {
  id                 String    @id @default(uuid())
  itemPcpId          String    @map("item_pcp_id")
  versao             Int       @default(1)
  nome               String
  rendimentoBase     Decimal   @map("rendimento_base") @db.Decimal(12, 3)
  perdaPercentual    Decimal?  @map("perda_percentual") @db.Decimal(5, 2)
  status             String    @default("ativa") // rascunho | ativa | inativa
  dataInicioVigencia DateTime  @map("data_inicio_vigencia")
  dataFimVigencia    DateTime? @map("data_fim_vigencia")
  observacoes        String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itemPcp        ItemPcp            @relation(fields: [itemPcpId], references: [id])
  itens          ReceitaItem[]
  ordensProducao OrdemProducao[]
  logs           ReceitaVersaoLog[]

  @@unique([itemPcpId, versao])
  @@index([status])
  @@map("receitas")
}

model ReceitaVersaoLog {
  id              String   @id @default(uuid())
  receitaId       String   @map("receita_id")
  versao          Int
  motivo          String   @db.Text
  alteracoes      Json
  alteradoPorId   String?  @map("alterado_por_id")
  alteradoPorNome String?  @map("alterado_por_nome")
  alteradoEm      DateTime @default(now()) @map("alterado_em")

  receita Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)

  @@index([receitaId])
  @@map("receita_versao_log")
}

model ReceitaItem {
  id         String  @id @default(uuid())
  receitaId  String  @map("receita_id")
  itemPcpId  String  @map("item_pcp_id")
  quantidade Decimal @db.Decimal(12, 3)
  tipo       String // MP | SUB | EMB
  ordem      Int     @default(0) // ordem de exibição do ingrediente na receita (definida no app)
  ordemEtapa String? @map("ordem_etapa") // preparo, modelagem, fritura, embalagem
  observacao String? @db.Text

  receita Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  itemPcp ItemPcp @relation(fields: [itemPcpId], references: [id])

  @@map("receita_itens")
}

model OrdemProducao {
  id                  String    @id @default(uuid())
  numero              Int       @unique @default(autoincrement())
  receitaId           String    @map("receita_id")
  quantidadePlanejada Decimal   @map("quantidade_planejada") @db.Decimal(12, 3)
  quantidadeProduzida Decimal   @default(0) @map("quantidade_produzida") @db.Decimal(12, 3)
  fatorEscala         Decimal   @map("fator_escala") @db.Decimal(10, 4)
  status              String    @default("PLANEJADA") // PLANEJADA | EM_PRODUCAO | FINALIZADA | CANCELADA
  receitaSnapshot     Json      @map("receita_snapshot")
  dataPlanejada       DateTime  @map("data_planejada")
  dataInicio          DateTime? @map("data_inicio")
  dataFim             DateTime? @map("data_fim")
  observacoes         String?   @db.Text
  criadoPorId         String?   @map("criado_por_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  receita      Receita          @relation(fields: [receitaId], references: [id])
  itensConsumo OrdemConsumo[]
  agendas      AgendaProducao[]

  @@index([status])
  @@index([dataPlanejada])
  @@map("ordens_producao")
}

model OrdemConsumo {
  id                 String  @id @default(uuid())
  ordemProducaoId    String  @map("ordem_producao_id")
  itemPcpId          String  @map("item_pcp_id")
  quantidadePrevista Decimal @map("quantidade_prevista") @db.Decimal(12, 3)
  quantidadeReal     Decimal @default(0) @map("quantidade_real") @db.Decimal(12, 3)
  tipo               String // MP | SUB | EMB

  createdAt DateTime @default(now()) @map("created_at")

  ordemProducao OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  itemPcp       ItemPcp       @relation(fields: [itemPcpId], references: [id])

  @@map("ordens_consumo")
}

model AgendaProducao {
  id              String   @id @default(uuid())
  ordemProducaoId String   @map("ordem_producao_id")
  titulo          String
  dataInicio      DateTime @map("data_inicio")
  dataFim         DateTime @map("data_fim")
  cor             String?  @default("#3B82F6")
  observacoes     String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ordemProducao OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)

  @@map("agenda_producao")
}

model MovimentacaoPcp {
  id              String  @id @default(uuid())
  itemPcpId       String  @map("item_pcp_id")
  tipo            String // ENTRADA | SAIDA
  quantidade      Decimal @db.Decimal(12, 3)
  motivo          String // PRODUCAO_ENTRADA | PRODUCAO_CONSUMO | AJUSTE_MANUAL | COMPRA
  ordemProducaoId String? @map("ordem_producao_id")
  observacao      String? @db.Text
  estoqueAntes    Decimal @map("estoque_antes") @db.Decimal(12, 3)
  estoqueDepois   Decimal @map("estoque_depois") @db.Decimal(12, 3)
  criadoPorId     String? @map("criado_por_id")

  createdAt DateTime @default(now()) @map("created_at")

  itemPcp ItemPcp @relation(fields: [itemPcpId], references: [id])

  @@index([itemPcpId])
  @@index([createdAt])
  @@map("movimentacoes_pcp")
}

model SugestaoProducao {
  id                 String  @id @default(uuid())
  itemPcpId          String  @map("item_pcp_id")
  quantidadeSugerida Decimal @map("quantidade_sugerida") @db.Decimal(12, 3)
  bateladas          Int     @default(1)
  motivo             String // ESTOQUE_MINIMO | DEMANDA_PEDIDOS
  status             String  @default("PENDENTE") // PENDENTE | ACEITA | REJEITADA
  ordemProducaoId    String? @map("ordem_producao_id")
  observacoes        String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itemPcp ItemPcp @relation(fields: [itemPcpId], references: [id])

  @@index([status])
  @@map("sugestoes_producao")
}

// =============================================
// MÓDULO DEVOLUÇÕES
// =============================================

model Devolucao {
  id               String @id @default(uuid())
  numero           Int    @default(autoincrement())
  pedidoOriginalId String @map("pedido_original_id")
  clienteId        String @map("cliente_id")

  tipo       String // ESPECIAL | CONTA_AZUL
  escopo     String // TOTAL | PARCIAL
  motivo     String  @db.Text
  observacao String? @db.Text

  // Campos exclusivos para devolução Conta Azul
  notaDevolucaoCA String? @map("nota_devolucao_ca")
  pdfDevolucaoUrl String? @map("pdf_devolucao_url")

  // Contexto da entrega original
  motoristaId         String?   @map("motorista_id")
  dataEntregaOriginal DateTime? @map("data_entrega_original")
  caixaDataReferencia String?   @map("caixa_data_referencia") // YYYY-MM-DD

  // Auditoria
  registradoPorId String   @map("registrado_por_id")
  dataDevolucao   DateTime @default(now()) @map("data_devolucao")

  // Status e reversão
  status         String    @default("ATIVA") // ATIVA | REVERTIDA
  revertidoPorId String?   @map("revertido_por_id")
  revertidoEm    DateTime? @map("revertido_em")
  motivoReversao String?   @map("motivo_reversao") @db.Text

  // Processamento Conta Azul (wizard boleto)
  processadoCA Boolean @default(false) @map("processado_ca")
  parcelaCAId  String? @map("parcela_ca_id") // UUID da parcela no CA
  pdfBoletoUrl String? @map("pdf_boleto_url") // PDF do novo boleto (parcial)
  wizardEtapa  String? @map("wizard_etapa") // Etapa atual do wizard (para retomar)

  // Financeiro
  valorTotal       Decimal @map("valor_total") @db.Decimal(12, 2)
  snapshotParcelas Json?   @map("snapshot_parcelas") // Snapshot das parcelas antes do ajuste

  // Relações
  pedidoOriginal Pedido          @relation(fields: [pedidoOriginalId], references: [id])
  cliente        Cliente         @relation(fields: [clienteId], references: [UUID])
  registradoPor  Vendedor        @relation("DevolucaoRegistrada", fields: [registradoPorId], references: [id])
  revertidoPor   Vendedor?       @relation("DevolucaoRevertida", fields: [revertidoPorId], references: [id])
  motorista      Vendedor?       @relation("DevolucaoMotorista", fields: [motoristaId], references: [id])
  itens          DevolucaoItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pedidoOriginalId])
  @@index([clienteId])
  @@index([status])
  @@index([dataDevolucao])
  @@map("devolucoes")
}

model DevolucaoItem {
  id            String  @id @default(uuid())
  devolucaoId   String  @map("devolucao_id")
  produtoId     String  @map("produto_id")
  quantidade    Decimal @db.Decimal(12, 3)
  valorUnitario Decimal @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal    Decimal @map("valor_total") @db.Decimal(12, 2)

  devolucao Devolucao @relation(fields: [devolucaoId], references: [id], onDelete: Cascade)
  produto   Produto   @relation(fields: [produtoId], references: [id])

  @@index([devolucaoId])
  @@map("devolucao_itens")
}

model IaAnaliseLog {
  id                    Int      @id @default(autoincrement())
  clienteId             String   @map("cliente_id")
  vendedorId            String?  @map("vendedor_id")
  disparadoPor          String   @map("disparado_por") // ATENDIMENTO | NOTURNO | MANUAL
  disparadoPorUsuarioId String?  @map("disparado_por_usuario_id")
  atendimentoId         String?  @map("atendimento_id")
  modelo                String   @default("gpt-4o-mini")
  promptEnviado         String   @map("prompt_enviado") @db.Text
  dadosEntrada          Json     @map("dados_entrada")
  respostaIa            Json?    @map("resposta_ia")
  tokensPrompt          Int?     @map("tokens_prompt")
  tokensResposta        Int?     @map("tokens_resposta")
  tokensTotal           Int?     @map("tokens_total")
  duracaoMs             Int?     @map("duracao_ms")
  sucesso               Boolean  @default(true)
  erroMsg               String?  @map("erro_msg")
  criadoEm              DateTime @default(now()) @map("criado_em")

  cliente Cliente @relation(fields: [clienteId], references: [UUID])

  @@index([clienteId])
  @@index([criadoEm(sort: Desc)])
  @@index([vendedorId])
  @@index([disparadoPor])
  @@map("ia_analise_logs")
}

model Curriculo {
  id           Int      @id @default(autoincrement())
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Dados pessoais
  nome           String
  email          String?
  whatsapp       String
  cpf            String   @unique
  dataNascimento DateTime @map("data_nascimento")
  estadoCivil    String?  @map("estado_civil")
  temFilhos      String?  @map("tem_filhos")
  naturalidade   String?
  endereco       String?
  foto           String?

  // Disponibilidade
  areaInteresse   String  @map("area_interesse")
  horarioInicio   String? @map("horario_inicio")
  horasExtras     String? @map("horas_extras")
  disponibilidade String?

  // Histórico profissional
  empregosRegistrados String? @map("empregos_registrados") @db.Text
  empregosSemRegistro String? @map("empregos_sem_registro") @db.Text
  outrasExperiencias  String? @map("outras_experiencias") @db.Text

  // Campos RH (preenchidos internamente)
  status        String    @default("Novo")
  observacao    String?   @db.Text
  dataAlteracao DateTime? @map("data_alteracao")

  // Relações
  acessos   CurriculoAcesso[]
  historico CurriculoHistorico[]

  @@map("curriculos")
}

model CurriculoAcesso {
  id          Int      @id @default(autoincrement())
  curriculoId Int      @map("curriculo_id")
  vendedorId  String   @map("vendedor_id")
  acessadoEm  DateTime @default(now()) @map("acessado_em")

  curriculo Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
  vendedor  Vendedor  @relation(fields: [vendedorId], references: [id])

  @@index([curriculoId])
  @@index([vendedorId])
  @@map("curriculo_acessos")
}

model CurriculoHistorico {
  id          Int      @id @default(autoincrement())
  curriculoId Int      @map("curriculo_id")
  vendedorId  String   @map("vendedor_id")
  campo       String
  valorAntes  String?  @map("valor_antes") @db.Text
  valorDepois String?  @map("valor_depois") @db.Text
  criadoEm    DateTime @default(now()) @map("criado_em")

  curriculo Curriculo @relation(fields: [curriculoId], references: [id], onDelete: Cascade)
  vendedor  Vendedor  @relation(fields: [vendedorId], references: [id])

  @@index([curriculoId])
  @@map("curriculo_historico")
}

// ─── Etiquetas de Produtos ────────────────────────────────────────────────────

model EtiquetaProduto {
  id String @id @default(uuid())

  // Vínculo opcional com Produto do catálogo (um produto pode ter várias etiquetas — tamanhos diferentes)
  produtoId String?  @map("produto_id")
  produto   Produto? @relation(fields: [produtoId], references: [id])

  // Identificação
  codigoProduto         String @map("codigo_produto")
  nomeProduto           String @map("nome_produto")
  pesoUnitario          Int    @map("peso_unitario") // gramas
  pesoTabelaNutricional Int    @map("peso_tabela_nutricional") // gramas (porção)

  // Informação Nutricional (texto com unidade + %VD, ex: "34kcal (2% VD)")
  valorEnergetico     String? @map("valor_energetico")
  carboidratos        String?
  acucaresTotais      String? @map("acucares_totais")
  acucaresAdicionados String? @map("acucares_adicionados")
  proteinas           String?
  gordurasTotais      String? @map("gorduras_totais")
  gordurasSaturadas   String? @map("gorduras_saturadas")
  gordurasTrans       String? @map("gorduras_trans")
  fibraAlimentar      String? @map("fibra_alimentar")
  sodio               String?

  // Conteúdo do rótulo
  quantidadeEmbalagem  Int     @map("quantidade_embalagem")
  quantidadeAproximada Boolean @default(false) @map("quantidade_aproximada")
  composicao           String  @db.Text
  modoPreparo          String  @map("modo_preparo") @db.Text
  codigoBarras         String? @map("codigo_barras")

  // Alérgenos
  contemLeite     Boolean  @default(false) @map("contem_leite")
  contemGluten    Boolean  @default(false) @map("contem_gluten")
  contemLactose   Boolean  @default(false) @map("contem_lactose")
  contemOvo       Boolean  @default(false) @map("contem_ovo")
  alergenos        String[] @default([]) // lista RDC 26/2015 marcada (ex: ["Leite","Soja","Ovos"])
  especieCrustaceos String? @map("especie_crustaceos") // nomes das espécies, ex: "camarão"
  especiePeixes     String? @map("especie_peixes")     // nomes das espécies, ex: "tilápia"
  outrosAlergenos  String?  @map("outros_alergenos")
  avisosRotulo     String?  @map("avisos_rotulo")

  // Conservação
  armazenamento String?
  validadeDias  Int     @default(90) @map("validade_dias")

  // Controle
  ativo       Boolean @default(true)
  tipoProduto String? @map("tipo_produto")
  tarjaPreta  Boolean @default(false) @map("tarja_preta")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([codigoProduto])
  @@map("etiquetas_produtos")
}

// =============================================
// MÓDULO COMISSÕES
// =============================================

model ComissaoConfig {
  id            String @id @default(uuid())
  vendedorId    String @map("vendedor_id")
  mesReferencia String @map("mes_referencia") // Formato "YYYY-MM"

  // Faixas de comissão — cada faixa tem um LIMITE (fronteira em % da meta) e uma TAXA (% de comissão)
  faixaAbaixo    Float @default(0) @map("faixa_abaixo") // fronteira inferior: acima de X% abaixo da meta começa a faixa "abaixo" (0 = qualquer valor abaixo da meta)
  percAbaixoMeta Float @default(0) @map("perc_abaixo_meta") // comissão % quando realizado < (meta - faixaAbaixo%)
  percNaMeta     Float @default(0) @map("perc_na_meta") // comissão % quando realizado está entre (meta - faixaAbaixo%) e meta
  faixaAcima     Float @default(0) @map("faixa_acima") // fronteira superior: bônus de excedente só começa além de X% acima da meta (0 = qualquer excedente)
  percAcimaMeta  Float @default(0) @map("perc_acima_meta") // comissão % sobre o excedente além de (meta + faixaAcima%)

  // Bônus independentes
  bonusCidades   Float @default(0) @map("bonus_cidades") // % adicional se bater meta em TODAS as cidades
  bonusProdutos  Float @default(0) @map("bonus_produtos") // % adicional por cada produto que bateu a meta
  bonusFlex      Float @default(0) @map("bonus_flex") // % adicional se uso de flex <= limiteFlexPerc
  limiteFlexPerc Float @default(100) @map("limite_flex_perc") // % máximo de uso do flex para ganhar bônus flex

  criadoPor String   @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendedor Vendedor @relation(fields: [vendedorId], references: [id])

  @@unique([vendedorId, mesReferencia])
  @@index([mesReferencia])
  @@map("comissao_config")
}

// ============================================================
// ── KIT FESTA — Site público de pedidos + Agenda da cozinha ──
// Módulo independente do Delivery* (que é o Kanban pós-pedido).
// Cliente acessa por link, faz pedido; admin aprova e converte
// em Pedido normal/especial.
// ============================================================

// Usuário do site (área do cliente). Pode ou não ter cadastro no CA (clienteUuid).
model KitFestaCliente {
  id        String  @id @default(uuid())
  cpf       String  @unique // só dígitos
  nome      String
  telefone  String?
  email     String?
  senhaHash String? @map("senha_hash") // null = ainda precisa criar senha

  // Vínculo com o cadastro do Conta Azul (quando existe)
  clienteUuid String?  @unique @map("cliente_uuid")
  cliente     Cliente? @relation(fields: [clienteUuid], references: [UUID])

  // Programa de indicação / fidelidade
  pontos           Int               @default(0)
  codigoIndicacao  String?           @unique @map("codigo_indicacao")
  creditoIndicacao Decimal           @default(0) @map("credito_indicacao") @db.Decimal(12, 2)
  indicadoPorId    String?           @map("indicado_por_id")
  indicadoPor      KitFestaCliente?  @relation("KitFestaIndicacao", fields: [indicadoPorId], references: [id])
  indicados        KitFestaCliente[] @relation("KitFestaIndicacao")

  // Recuperação de senha
  resetToken    String?   @map("reset_token")
  resetTokenExp DateTime? @map("reset_token_exp")

  ultimoAcesso DateTime? @map("ultimo_acesso")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  pedidos KitFestaPedido[]

  @@index([cpf])
  @@map("kitfesta_clientes")
}

// Categorias de exibição no site (ex: Fritos, De forno, Doces). Editável pelo admin.
model KitFestaCategoria {
  id        String   @id @default(uuid())
  nome      String
  slug      String   @unique // ex: 'fritos', 'forno', 'doces'
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  produtos KitFestaProduto[]

  @@map("kitfesta_categorias")
}

// Vincula um Produto do app ao site, com config de exibição.
model KitFestaProduto {
  id        String  @id @default(uuid())
  produtoId String  @unique @map("produto_id")
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  categoriaId String?            @map("categoria_id")
  categoria   KitFestaCategoria? @relation(fields: [categoriaId], references: [id])

  unidadesPorCaixa Int      @default(25) @map("unidades_por_caixa")
  precoKitFesta    Decimal? @map("preco_kitfesta") @db.Decimal(12, 2) // override; null = usa valorVenda do Produto
  descricaoSite    String?  @map("descricao_site") @db.Text
  tags             String[] @default([])
  opcoes           String[] @default([]) // ex: ['Frango','Palmito']
  destaque         Boolean  @default(false) // "Mais pedidos"
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens KitFestaPedidoItem[]

  @@index([ativo])
  @@map("kitfesta_produtos")
}

// Status do dia na agenda da cozinha. Sem registro = usa default (aberto se houver horário no template).
model KitFestaAgendaDia {
  id         String   @id @default(uuid())
  data       DateTime @unique @db.Date
  status     String   @default("open") // open | few | full | closed
  observacao String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("kitfesta_agenda_dias")
}

// LEGADO — template antigo por dia-da-semana. Mantido para não dropar a coluna em produção.
// Não é mais a fonte dos slots do site (agora é KitFestaHorarioDia, por data específica).
model KitFestaHorarioPadrao {
  id         String   @id @default(uuid())
  modo       String // retirada | entrega
  hora       String // '08:30'
  capacidade Int      @default(10) // pedidos por slot
  diasSemana Int[]    @default([]) @map("dias_semana") // 0=Dom ... 6=Sáb; vazio = todos
  ativo      Boolean  @default(true)
  ordem      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("kitfesta_horarios_padrao")
}

// Slots de horário POR DATA específica (fonte de verdade da agenda).
// Configurados em lote (período) e/ou ajustados por dia no admin.
model KitFestaHorarioDia {
  id         String   @id @default(uuid())
  data       DateTime @db.Date
  modo       String   // retirada | entrega
  hora       String   // '06:00', '06:30'...
  capacidade Int      @default(10) // pedidos que esse horário aceita
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([data, modo, hora])
  @@index([data])
  @@map("kitfesta_horarios_dia")
}

// Bairros de entrega com CEP e taxa.
model KitFestaBairro {
  id        String   @id @default(uuid())
  nome      String
  cidade    String?  @default("Joinville")
  cep       String? // CEP base ou principal do bairro
  taxa      Decimal  @default(0) @db.Decimal(12, 2)
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  pedidos KitFestaPedido[]

  @@map("kitfesta_bairros")
}

// Cupons de desconto.
model KitFestaCupom {
  id             String    @id @default(uuid())
  codigo         String    @unique
  tipo           String // pct | brl
  valor          Decimal   @db.Decimal(12, 2)
  label          String?
  minCaixas      Int?      @map("min_caixas")
  validade       DateTime? @db.Date
  primeiraCompra Boolean   @default(false) @map("primeira_compra")
  usoMaximo      Int?      @map("uso_maximo") // total de usos permitidos (null = ilimitado)
  usos           Int       @default(0)
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("kitfesta_cupons")
}

// Pedido feito no site. Entra numa fila; admin aprova e converte em Pedido normal/especial.
model KitFestaPedido {
  id     String @id @default(uuid())
  numero Int    @unique @default(autoincrement())

  // Cliente do site (sempre presente; pode estar sem cadastro CA)
  kitFestaClienteId String          @map("kitfesta_cliente_id")
  kitFestaCliente   KitFestaCliente @relation(fields: [kitFestaClienteId], references: [id])

  // Snapshot dos dados do cliente no momento do pedido
  nomeCliente     String  @map("nome_cliente")
  cpfCliente      String  @map("cpf_cliente")
  telefoneCliente String? @map("telefone_cliente")
  celularAlterado Boolean @default(false) @map("celular_alterado") // cliente informou/corrigiu o nº no checkout — admin deve atualizar no cadastro
  semCadastro     Boolean @default(false) @map("sem_cadastro") // visitante sem Cliente no app/CA

  // Entrega
  modo            String // retirada | entrega
  data            DateTime        @db.Date
  horario         String
  bairroId        String?         @map("bairro_id")
  bairro          KitFestaBairro? @relation(fields: [bairroId], references: [id])
  taxaEntrega     Decimal         @default(0) @map("taxa_entrega") @db.Decimal(12, 2)
  enderecoEntrega String?         @map("endereco_entrega") @db.Text

  // Valores
  subtotal      Decimal @db.Decimal(12, 2)
  cupomCodigo   String? @map("cupom_codigo")
  descontoValor Decimal @default(0) @map("desconto_valor") @db.Decimal(12, 2)
  total         Decimal @db.Decimal(12, 2)
  totalCaixas   Int     @map("total_caixas")

  observacoes String? @db.Text

  // Fluxo de aprovação
  // AGUARDANDO | PENDENTE_CADASTRO | APROVADO | RECUSADO | CONVERTIDO | CANCELADO
  status       String  @default("AGUARDANDO")
  motivoRecusa String? @map("motivo_recusa") @db.Text

  // Conversão para Pedido normal
  tipoConversao String?   @map("tipo_conversao") // NORMAL | ESPECIAL | BONIFICACAO
  pedidoId      String?   @unique @map("pedido_id")
  pedido        Pedido?   @relation(fields: [pedidoId], references: [id])
  aprovadoPorId String?   @map("aprovado_por_id")
  aprovadoEm    DateTime? @map("aprovado_em")

  whatsappEnviado Boolean @default(false) @map("whatsapp_enviado")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens KitFestaPedidoItem[]

  @@index([status])
  @@index([data])
  @@index([kitFestaClienteId])
  @@map("kitfesta_pedidos")
}

model KitFestaPedidoItem {
  id               String         @id @default(uuid())
  kitFestaPedidoId String         @map("kitfesta_pedido_id")
  kitFestaPedido   KitFestaPedido @relation(fields: [kitFestaPedidoId], references: [id], onDelete: Cascade)

  kitFestaProdutoId String?          @map("kitfesta_produto_id")
  kitFestaProduto   KitFestaProduto? @relation(fields: [kitFestaProdutoId], references: [id])

  nomeProduto      String  @map("nome_produto")
  opcao            String? // ex: 'Frango' / 'Palmito'
  quantidade       Int // nº de caixas
  unidadesPorCaixa Int     @map("unidades_por_caixa")
  precoUnitario    Decimal @map("preco_unitario") @db.Decimal(12, 2)

  @@map("kitfesta_pedido_itens")
}

// Configurações do site (chave/valor). Ex: hero, como_funciona, loja, regras, frete_texto.
model KitFestaConfig {
  chave     String   @id
  valor     Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kitfesta_config")
}

// Avaliações exibidas no site, gerenciadas pelo admin.
model KitFestaAvaliacao {
  id        String   @id @default(uuid())
  nome      String
  evento    String?
  texto     String   @db.Text
  estrelas  Int      @default(5)
  dataLabel String?  @map("data_label")
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("kitfesta_avaliacoes")
}

// =============================================
// SITE CONGELADOS (B2B / revenda)
// Espelha a arquitetura do Kit Festa, mas personalizado por cliente:
// preços, condições de pagamento e dias de entrega vêm do cadastro do app.
// =============================================

// Login do cliente do site de congelados. CPF ou CNPJ (só dígitos).
model CongeladosCliente {
  id        String  @id @default(uuid())
  documento String  @unique // só dígitos (CPF 11 ou CNPJ 14)
  nome      String
  telefone  String?
  email     String?
  senhaHash String? @map("senha_hash") // null = ainda precisa criar senha

  // Vínculo com o cadastro do Conta Azul (quando existe)
  clienteUuid String?  @unique @map("cliente_uuid")
  cliente     Cliente? @relation(fields: [clienteUuid], references: [UUID])

  // Recuperação de senha
  resetToken    String?   @map("reset_token")
  resetTokenExp DateTime? @map("reset_token_exp")

  ultimoAcesso DateTime? @map("ultimo_acesso")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  pedidos CongeladosPedido[]

  @@index([documento])
  @@map("congelados_clientes")
}

// Vincula um Produto do app ao catálogo de congelados, com config de exibição.
// A categoria de filtro vem da CategoriaProduto (categoria comercial) do próprio Produto.
model CongeladosProduto {
  id        String  @id @default(uuid())
  produtoId String  @unique @map("produto_id")
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  unidadesPorCaixa Int      @default(0) @map("unidades_por_caixa") // 0 = usa a unidade do produto
  embalagem        String   @default("caixa") // rótulo da embalagem no site (caixa, pacote, unidade...)
  nomeSite         String?  @map("nome_site") // nome exibido no site; null = nome do sistema. O pedido no sistema sempre usa o nome do sistema.
  precoCongelados  Decimal? @map("preco_congelados") @db.Decimal(12, 2) // override; null = usa valorVenda
  descricaoSite    String?  @map("descricao_site") @db.Text
  destaque         Boolean  @default(false) // "Mais pedidos" na home
  ordem            Int      @default(0)
  ativo            Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens CongeladosPedidoItem[]

  @@index([ativo])
  @@map("congelados_produtos")
}

// Pedido feito no site de congelados. Entra numa fila; admin vincula/aprova e
// converte em Pedido normal ou especial (respeitando a condição de pagamento).
model CongeladosPedido {
  id     String @id @default(uuid())
  numero Int    @unique @default(autoincrement())

  congeladosClienteId String            @map("congelados_cliente_id")
  congeladosCliente   CongeladosCliente @relation(fields: [congeladosClienteId], references: [id])

  // Snapshot dos dados do cliente no momento do pedido
  nomeCliente      String  @map("nome_cliente")
  documentoCliente String  @map("documento_cliente")
  telefoneCliente  String? @map("telefone_cliente")
  celularAlterado  Boolean @default(false) @map("celular_alterado")
  semCadastro      Boolean @default(false) @map("sem_cadastro") // visitante sem Cliente no app/CA

  // Condição de pagamento e entrega escolhidas (vindas do cadastro do cliente)
  tabelaPrecoId String? @map("tabela_preco_id") // id da TabelaPreco (condição) escolhida
  condicaoNome  String? @map("condicao_nome")
  diaEntrega    String? @map("dia_entrega")
  dataEntrega   DateTime? @map("data_entrega") // data de entrega/retirada escolhida no site
  modo          String  @default("entrega") // entrega | retirada (retirar na loja)
  encaixe       Boolean   @default(false) // pedido fora do dia regular do cliente (equipe verifica viabilidade)

  // Valores
  subtotal    Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  totalCaixas Int     @map("total_caixas")

  observacoes String? @db.Text

  // Fluxo: AGUARDANDO | PENDENTE_CADASTRO | RECUSADO | CONVERTIDO | CANCELADO
  status       String  @default("AGUARDANDO")
  motivoRecusa String? @map("motivo_recusa") @db.Text

  // Conversão para Pedido normal/especial
  tipoConversao String?   @map("tipo_conversao") // NORMAL | ESPECIAL | BONIFICACAO
  pedidoId      String?   @unique @map("pedido_id")
  pedido        Pedido?   @relation(fields: [pedidoId], references: [id])
  aprovadoPorId String?   @map("aprovado_por_id")
  aprovadoEm    DateTime? @map("aprovado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itens CongeladosPedidoItem[]

  @@index([status])
  @@index([congeladosClienteId])
  @@map("congelados_pedidos")
}

model CongeladosPedidoItem {
  id                 String           @id @default(uuid())
  congeladosPedidoId String           @map("congelados_pedido_id")
  congeladosPedido   CongeladosPedido @relation(fields: [congeladosPedidoId], references: [id], onDelete: Cascade)

  congeladosProdutoId String?            @map("congelados_produto_id")
  congeladosProduto   CongeladosProduto? @relation(fields: [congeladosProdutoId], references: [id])

  nomeProduto      String  @map("nome_produto")
  quantidade       Int // nº de caixas
  unidadesPorCaixa Int     @default(0) @map("unidades_por_caixa")
  precoUnitario    Decimal @map("preco_unitario") @db.Decimal(12, 2)

  @@map("congelados_pedido_itens")
}

// Configurações do site de congelados (chave/valor).
model CongeladosConfig {
  chave     String   @id
  valor     Json?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("congelados_config")
}
